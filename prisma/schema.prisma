// Fresha-inspired business management platform — Prisma schema
// Docs: https://www.prisma.io/docs

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ------------------------------------------------------------------
// Enums
// ------------------------------------------------------------------

enum Role {
  ADMIN
  MANAGER // Manager / Receptionist
  TEAM_MEMBER
}

enum AppointmentStatus {
  BOOKED
  CONFIRMED
  ARRIVED
  IN_PROGRESS
  COMPLETED
  CANCELLED
  NO_SHOW
  WAITLIST
}

enum PaymentMethod {
  CASH
  CARD
  ESEWA
  KHALTI
  FONEPAY
  IMEPAY
  BANK_TRANSFER
  LOYALTY_POINTS
  COMPLIMENTARY
}

enum PaymentStatus {
  PENDING
  INITIATED
  COMPLETED
  FAILED
  CANCELLED
  REFUNDED
  PARTIALLY_REFUNDED
}

enum InvoiceStatus {
  DRAFT
  ISSUED
  PAID
  PARTIALLY_PAID
  VOID
  REFUNDED
}

enum PaymentGateway {
  ESEWA
  KHALTI
  FONEPAY
  IMEPAY
}

enum MembershipStatus {
  ACTIVE
  EXPIRED
  CANCELLED
}

enum NotificationChannel {
  IN_APP
  EMAIL
  SMS
}

enum NotificationType {
  APPOINTMENT_REMINDER
  APPOINTMENT_CONFIRMATION
  PAYMENT_CONFIRMATION
  PAYMENT_FAILED
  LOW_STOCK
  GENERAL
}

enum LeaveStatus {
  PENDING
  APPROVED
  REJECTED
}

enum PurchaseOrderStatus {
  DRAFT
  ORDERED
  PARTIALLY_RECEIVED
  RECEIVED
  CANCELLED
}

enum StockMovementType {
  PURCHASE
  SALE
  ADJUSTMENT
  RETURN
  CONSUMPTION
}

// ------------------------------------------------------------------
// Tenancy / Branches
// ------------------------------------------------------------------

model Business {
  id        String   @id @default(cuid())
  name      String
  currency  String   @default("NPR")
  timezone  String   @default("Asia/Kathmandu")
  logoUrl   String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  branches Branch[]
}

model Branch {
  id         String   @id @default(cuid())
  businessId String
  name       String
  address    String?
  city       String?
  phone      String?
  email      String?
  isActive   Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  business      Business       @relation(fields: [businessId], references: [id], onDelete: Cascade)
  memberships   UserBranch[]
  staff         Staff[]
  services      Service[]
  appointments  Appointment[]
  invoices      Invoice[]
  products      Product[]
  purchaseOrders PurchaseOrder[]
  stockMovements StockMovement[]

  @@index([businessId])
}

// ------------------------------------------------------------------
// Auth: Users, Roles, Permissions, NextAuth models
// ------------------------------------------------------------------

model User {
  id            String    @id @default(cuid())
  name          String
  email         String    @unique
  emailVerified DateTime?
  passwordHash  String?
  image         String?
  role          Role      @default(TEAM_MEMBER)
  phone         String?
  isActive      Boolean   @default(true)
  lastLoginAt   DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  branches        UserBranch[]
  staffProfile    Staff?
  accounts        Account[]
  sessions        Session[]
  permissions     UserPermission[]
  auditLogs       AuditLog[]
  notifications   Notification[]
  createdInvoices Invoice[]        @relation("InvoiceCreatedBy")

  @@index([role])
}

// Fine-grained permission overrides layered on top of role defaults.
model Permission {
  id          String           @id @default(cuid())
  key         String           @unique // e.g. "appointment.create"
  description String?
  users       UserPermission[]
}

model UserPermission {
  userId       String
  permissionId String
  granted      Boolean @default(true) // allow explicit deny as well

  user       User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  permission Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@id([userId, permissionId])
}

// Maps a user to the branches they can access.
model UserBranch {
  userId   String
  branchId String
  isPrimary Boolean @default(false)

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  branch Branch @relation(fields: [branchId], references: [id], onDelete: Cascade)

  @@id([userId, branchId])
  @@index([branchId])
}

// NextAuth adapter models
model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ------------------------------------------------------------------
// Staff
// ------------------------------------------------------------------

model Staff {
  id             String   @id @default(cuid())
  userId         String   @unique
  branchId       String
  jobTitle       String?
  bio            String?
  commissionRate Decimal  @default(0) @db.Decimal(5, 2) // percentage
  isBookable     Boolean  @default(true)
  color          String?  // calendar color
  hiredAt        DateTime?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  user          User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  branch        Branch          @relation(fields: [branchId], references: [id], onDelete: Cascade)
  workingHours  WorkingHour[]
  leaves        Leave[]
  appointments  Appointment[]
  services      StaffService[]
  commissions   Commission[]
  attendance    Attendance[]

  @@index([branchId])
}

model WorkingHour {
  id        String @id @default(cuid())
  staffId   String
  dayOfWeek Int    // 0 = Sunday ... 6 = Saturday
  startTime String // "09:00"
  endTime   String // "18:00"
  isOff     Boolean @default(false)

  staff Staff @relation(fields: [staffId], references: [id], onDelete: Cascade)

  @@unique([staffId, dayOfWeek])
}

model Leave {
  id        String      @id @default(cuid())
  staffId   String
  startDate DateTime
  endDate   DateTime
  reason    String?
  status    LeaveStatus @default(PENDING)
  createdAt DateTime    @default(now())

  staff Staff @relation(fields: [staffId], references: [id], onDelete: Cascade)

  @@index([staffId])
}

model Attendance {
  id        String    @id @default(cuid())
  staffId   String
  date      DateTime  @db.Date
  clockIn   DateTime?
  clockOut  DateTime?
  note      String?

  staff Staff @relation(fields: [staffId], references: [id], onDelete: Cascade)

  @@unique([staffId, date])
}

model Commission {
  id            String   @id @default(cuid())
  staffId       String
  invoiceItemId String?
  amount        Decimal  @db.Decimal(12, 2)
  rate          Decimal  @db.Decimal(5, 2)
  earnedAt      DateTime @default(now())

  staff       Staff        @relation(fields: [staffId], references: [id], onDelete: Cascade)
  invoiceItem InvoiceItem? @relation(fields: [invoiceItemId], references: [id], onDelete: SetNull)

  @@index([staffId])
}

// ------------------------------------------------------------------
// Services
// ------------------------------------------------------------------

model ServiceCategory {
  id        String    @id @default(cuid())
  name      String
  color     String?
  sortOrder Int       @default(0)
  services  Service[]
}

model Service {
  id              String   @id @default(cuid())
  branchId        String
  categoryId      String?
  name            String
  description     String?
  durationMinutes Int      @default(30)
  price           Decimal  @db.Decimal(12, 2)
  taxRate         Decimal  @default(13) @db.Decimal(5, 2) // Nepal VAT 13%
  isActive        Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  branch       Branch           @relation(fields: [branchId], references: [id], onDelete: Cascade)
  category     ServiceCategory? @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  staff        StaffService[]
  addOns       ServiceAddOn[]
  appointments AppointmentService[]

  @@index([branchId])
  @@index([categoryId])
}

model ServiceAddOn {
  id              String  @id @default(cuid())
  serviceId       String
  name            String
  price           Decimal @db.Decimal(12, 2)
  durationMinutes Int     @default(0)

  service Service @relation(fields: [serviceId], references: [id], onDelete: Cascade)
}

model StaffService {
  staffId   String
  serviceId String

  staff   Staff   @relation(fields: [staffId], references: [id], onDelete: Cascade)
  service Service @relation(fields: [serviceId], references: [id], onDelete: Cascade)

  @@id([staffId, serviceId])
}

// ------------------------------------------------------------------
// Customers
// ------------------------------------------------------------------

model Customer {
  id            String    @id @default(cuid())
  businessId    String    // shared across branches
  firstName     String
  lastName      String?
  email         String?
  phone         String?
  gender        String?
  dateOfBirth   DateTime?
  address       String?
  notes         String?
  loyaltyPoints Int       @default(0)
  isBlocked     Boolean   @default(false)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  appointments Appointment[]
  invoices     Invoice[]
  memberships  Membership[]
  packages     CustomerPackage[]

  @@index([businessId])
  @@index([phone])
  @@index([email])
}

model MembershipPlan {
  id            String   @id @default(cuid())
  name          String
  description   String?
  price         Decimal  @db.Decimal(12, 2)
  durationDays  Int      @default(365)
  discountRate  Decimal  @default(0) @db.Decimal(5, 2)
  isActive      Boolean  @default(true)

  memberships Membership[]
}

model Membership {
  id         String           @id @default(cuid())
  customerId String
  planId     String
  status     MembershipStatus @default(ACTIVE)
  startDate  DateTime         @default(now())
  endDate    DateTime
  createdAt  DateTime         @default(now())

  customer Customer       @relation(fields: [customerId], references: [id], onDelete: Cascade)
  plan     MembershipPlan @relation(fields: [planId], references: [id], onDelete: Cascade)

  @@index([customerId])
}

model Package {
  id          String   @id @default(cuid())
  name        String
  description String?
  price       Decimal  @db.Decimal(12, 2)
  totalSessions Int
  validityDays Int     @default(365)
  isActive    Boolean  @default(true)

  customerPackages CustomerPackage[]
}

model CustomerPackage {
  id                String   @id @default(cuid())
  customerId        String
  packageId         String
  remainingSessions Int
  purchasedAt       DateTime @default(now())
  expiresAt         DateTime

  customer Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
  package  Package  @relation(fields: [packageId], references: [id], onDelete: Cascade)

  @@index([customerId])
}

// ------------------------------------------------------------------
// Appointments
// ------------------------------------------------------------------

model Appointment {
  id          String            @id @default(cuid())
  branchId    String
  customerId  String?
  staffId     String?
  status      AppointmentStatus @default(BOOKED)
  startTime   DateTime
  endTime     DateTime
  notes       String?
  isOnline    Boolean           @default(false) // booked via online booking
  reminderSent Boolean          @default(false)
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt

  branch   Branch               @relation(fields: [branchId], references: [id], onDelete: Cascade)
  customer Customer?            @relation(fields: [customerId], references: [id], onDelete: SetNull)
  staff    Staff?               @relation(fields: [staffId], references: [id], onDelete: SetNull)
  services AppointmentService[]
  invoice  Invoice?

  @@index([branchId, startTime])
  @@index([staffId])
  @@index([customerId])
  @@index([status])
}

model AppointmentService {
  id              String  @id @default(cuid())
  appointmentId   String
  serviceId       String
  priceAtBooking  Decimal @db.Decimal(12, 2)
  durationMinutes Int

  appointment Appointment @relation(fields: [appointmentId], references: [id], onDelete: Cascade)
  service     Service     @relation(fields: [serviceId], references: [id], onDelete: Cascade)

  @@index([appointmentId])
}

// ------------------------------------------------------------------
// Billing: Invoices, Items, Payments, Refunds
// ------------------------------------------------------------------

model Invoice {
  id            String        @id @default(cuid())
  invoiceNumber String        @unique
  branchId      String
  customerId    String?
  appointmentId String?       @unique
  createdById   String?
  status        InvoiceStatus @default(DRAFT)
  subtotal      Decimal       @db.Decimal(12, 2)
  discountTotal Decimal       @default(0) @db.Decimal(12, 2)
  taxTotal      Decimal       @default(0) @db.Decimal(12, 2)
  total         Decimal       @db.Decimal(12, 2)
  amountPaid    Decimal       @default(0) @db.Decimal(12, 2)
  notes         String?
  issuedAt      DateTime      @default(now())
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  branch      Branch        @relation(fields: [branchId], references: [id], onDelete: Cascade)
  customer    Customer?     @relation(fields: [customerId], references: [id], onDelete: SetNull)
  appointment Appointment?  @relation(fields: [appointmentId], references: [id], onDelete: SetNull)
  createdBy   User?         @relation("InvoiceCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  items       InvoiceItem[]
  payments    Payment[]

  @@index([branchId, issuedAt])
  @@index([customerId])
  @@index([status])
}

model InvoiceItem {
  id           String   @id @default(cuid())
  invoiceId    String
  description  String
  serviceId    String?
  productId    String?
  staffId      String?  // for commission attribution
  quantity     Int      @default(1)
  unitPrice    Decimal  @db.Decimal(12, 2)
  discount     Decimal  @default(0) @db.Decimal(12, 2)
  taxRate      Decimal  @default(0) @db.Decimal(5, 2)
  lineTotal    Decimal  @db.Decimal(12, 2)

  invoice     Invoice      @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  commissions Commission[]

  @@index([invoiceId])
}

model Payment {
  id              String         @id @default(cuid())
  invoiceId       String
  amount          Decimal        @db.Decimal(12, 2)
  method          PaymentMethod
  status          PaymentStatus  @default(PENDING)
  gateway         PaymentGateway?
  transactionId   String?        // our reference (product_id / purchase_order_id)
  gatewayRef      String?        // gateway transaction reference
  rawResponse     Json?
  paidAt          DateTime?
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  invoice Invoice  @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  refunds Refund[]

  @@index([invoiceId])
  @@index([status])
  @@index([transactionId])
}

model Refund {
  id            String        @id @default(cuid())
  paymentId     String
  amount        Decimal       @db.Decimal(12, 2)
  reason        String?
  status        PaymentStatus @default(PENDING)
  gatewayRef    String?
  processedAt   DateTime?
  createdAt     DateTime      @default(now())

  payment Payment @relation(fields: [paymentId], references: [id], onDelete: Cascade)

  @@index([paymentId])
}

// ------------------------------------------------------------------
// Inventory
// ------------------------------------------------------------------

model Supplier {
  id        String   @id @default(cuid())
  name      String
  contact   String?
  email     String?
  phone     String?
  address   String?
  createdAt DateTime @default(now())

  products       Product[]
  purchaseOrders PurchaseOrder[]
}

model Product {
  id            String   @id @default(cuid())
  branchId      String
  supplierId    String?
  name          String
  sku           String?
  description   String?
  costPrice     Decimal  @default(0) @db.Decimal(12, 2)
  sellPrice     Decimal  @default(0) @db.Decimal(12, 2)
  quantity      Int      @default(0)
  lowStockLevel Int      @default(5)
  unit          String   @default("pcs")
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  branch         Branch              @relation(fields: [branchId], references: [id], onDelete: Cascade)
  supplier       Supplier?           @relation(fields: [supplierId], references: [id], onDelete: SetNull)
  stockMovements StockMovement[]
  poItems        PurchaseOrderItem[]

  @@index([branchId])
  @@unique([branchId, sku])
}

model StockMovement {
  id        String            @id @default(cuid())
  branchId  String
  productId String
  type      StockMovementType
  quantity  Int               // positive in, negative out
  reason    String?
  createdAt DateTime          @default(now())

  branch  Branch  @relation(fields: [branchId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId])
}

model PurchaseOrder {
  id          String              @id @default(cuid())
  branchId    String
  supplierId  String?
  poNumber    String              @unique
  status      PurchaseOrderStatus @default(DRAFT)
  total       Decimal             @default(0) @db.Decimal(12, 2)
  orderedAt   DateTime?
  receivedAt  DateTime?
  createdAt   DateTime            @default(now())

  branch   Branch              @relation(fields: [branchId], references: [id], onDelete: Cascade)
  supplier Supplier?           @relation(fields: [supplierId], references: [id], onDelete: SetNull)
  items    PurchaseOrderItem[]

  @@index([branchId])
}

model PurchaseOrderItem {
  id              String  @id @default(cuid())
  purchaseOrderId String
  productId       String
  quantity        Int
  receivedQty     Int     @default(0)
  unitCost        Decimal @db.Decimal(12, 2)

  purchaseOrder PurchaseOrder @relation(fields: [purchaseOrderId], references: [id], onDelete: Cascade)
  product       Product       @relation(fields: [productId], references: [id], onDelete: Cascade)
}

// ------------------------------------------------------------------
// Notifications & Audit
// ------------------------------------------------------------------

model Notification {
  id        String              @id @default(cuid())
  userId    String
  type      NotificationType
  channel   NotificationChannel @default(IN_APP)
  title     String
  body      String
  isRead    Boolean             @default(false)
  metadata  Json?
  createdAt DateTime            @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, isRead])
}

model AuditLog {
  id         String   @id @default(cuid())
  userId     String?
  action     String   // e.g. "appointment.created"
  entity     String   // e.g. "Appointment"
  entityId   String?
  metadata   Json?
  ipAddress  String?
  userAgent  String?
  createdAt  DateTime @default(now())

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([entity, entityId])
  @@index([createdAt])
}
