# ------------------------------------------------------------------
# Database (local PostgreSQL)
# ------------------------------------------------------------------
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/business_app?schema=public"
# For Prisma migrate (same as DATABASE_URL for a plain local Postgres):
DIRECT_URL="postgresql://postgres:postgres@localhost:5432/business_app?schema=public"

# ------------------------------------------------------------------
# Auth (NextAuth / Auth.js)
# ------------------------------------------------------------------
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET="dev-secret-change-me"
NEXTAUTH_URL="http://localhost:3000"

# ------------------------------------------------------------------
# App
# ------------------------------------------------------------------
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NODE_ENV="development"
